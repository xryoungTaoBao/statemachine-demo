<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yubzhou.statemachine.order.mapper.OrderEventLogMapper">

    <resultMap id="BaseResultMap" type="com.yubzhou.statemachine.order.entity.OrderEventLog">
        <id column="id" property="id"/>
        <result column="order_id" property="orderId"/>
        <result column="order_no" property="orderNo"/>
        <result column="event" property="event"/>
        <result column="event_data" property="eventData"/>
        <result column="current_state" property="currentState"/>
        <result column="target_state" property="targetState"/>
        <result column="result" property="result"/>
        <result column="error_code" property="errorCode"/>
        <result column="error_message" property="errorMessage"/>
        <result column="execution_time_ms" property="executionTimeMs"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, order_id, order_no, event, event_data, current_state, target_state,
        result, error_code, error_message, execution_time_ms, create_time
    </sql>

    <!-- 根据订单ID查询事件日志 -->
    <select id="selectByOrderId" resultMap="BaseResultMap">
        SELECT
            <include refid="Base_Column_List"/>
        FROM t_order_event_log
        WHERE order_id = #{orderId}
        ORDER BY create_time DESC
    </select>

    <!-- 清理过期日志 -->
    <delete id="deleteByCreateTimeBefore">
        DELETE FROM t_order_event_log
        WHERE create_time &lt; #{before}
    </delete>

</mapper>
